<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Network permission -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Voice input: recording permission -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Install APK permission (Android 8+) -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:name=".NovaApplication"
        android:supportsRtl="true"
        android:theme="@style/Theme.MyAndroidApp"
        android:usesCleartextTraffic="true">

        <!-- FileProvider: used for sharing files during APK installation -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- SessionListActivity as launcher activity -->
        <activity
            android:name=".SessionListActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <!-- ChatActivity -->
        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:label="@string/title_chat"
            android:windowSoftInputMode="adjustResize" />

        <!-- SessionSettingsActivity -->
        <activity
            android:name=".SessionSettingsActivity"
            android:exported="false"
            android:label="@string/title_session_settings" />

        <!-- SettingsActivity -->
        <activity
            android:name=".SettingsActivity"
            android:exported="false"
            android:label="@string/title_settings" />

        <!-- AboutActivity -->
        <activity
            android:name=".AboutActivity"
            android:exported="false"
            android:label="@string/title_about" />

        <!-- AccountManagerActivity -->
        <activity
            android:name=".AccountManagerActivity"
            android:exported="false"
            android:label="@string/title_account_manager" />

        <!-- AccountEditActivity -->
        <activity
            android:name=".AccountEditActivity"
            android:exported="false"
            android:label="@string/title_account_edit" />

        <!-- LogViewerActivity -->
        <activity
            android:name=".LogViewerActivity"
            android:exported="false"
            android:label="@string/title_log_viewer" />

    </application>

</manifest>

