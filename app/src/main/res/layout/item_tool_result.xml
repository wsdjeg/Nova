<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:gravity="start">

    <!-- 工具结果卡片 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/tool_result_bg"
        android:padding="12dp">

        <!-- Tool result header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/statusIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:paddingEnd="4dp" />

            <TextView
                android:id="@+id/toolNameText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="220dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/tool_name_color"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/expandHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="展开 ▼"
                android:textSize="11sp"
                android:textColor="@color/tool_name_color"
                android:padding="4dp"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Tool result content container - 可滚动 -->
        <HorizontalScrollView
            android:id="@+id/contentScrollH"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:scrollbars="horizontal"
            android:fillViewport="false">

            <net.wsdjeg.nova.ToolContentScrollView
                android:id="@+id/contentScrollV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scrollbars="vertical"
                android:fillViewport="false">

                <TextView
                    android:id="@+id/contentText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="296dp"
                    android:padding="8dp"
                    android:background="@color/code_block_bg"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:visibility="gone" />

            </net.wsdjeg.nova.ToolContentScrollView>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- 时间戳 -->
    <TextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:textSize="12sp"
        android:textColor="@color/time_text" />

</LinearLayout>

