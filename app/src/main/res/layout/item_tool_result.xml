<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:gravity="start">

    <!-- 工具结果卡片 - 90% 屏幕宽度 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="1.0">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.9"
            android:orientation="vertical"
            android:background="@drawable/tool_result_bg"
            android:padding="12dp">

            <!-- Tool result header -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/statusIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:paddingEnd="4dp" />

                <TextView
                    android:id="@+id/toolNameText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2196F3"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/expandHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="展开 ▼"
                    android:textSize="11sp"
                    android:textColor="#2196F3"
                    android:padding="4dp"
                    android:visibility="gone" />

            </LinearLayout>

            <!-- Tool result content container - 禁用嵌套滚动避免与 RecyclerView 冲突 -->
            <androidx.core.widget.NestedScrollView
                android:id="@+id/contentScrollV"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:scrollbars="vertical"
                android:fillViewport="false"
                android:nestedScrollingEnabled="false">

                <HorizontalScrollView
                    android:id="@+id/contentScrollH"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal"
                    android:fillViewport="false">

                    <TextView
                        android:id="@+id/contentText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:background="@color/ai_message_bg"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:fontFamily="monospace" />

                </HorizontalScrollView>

            </androidx.core.widget.NestedScrollView>

        </LinearLayout>

    </LinearLayout>

    <!-- 时间戳 -->
    <TextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginStart="8dp"
        android:textSize="12sp"
        android:textColor="#999999" />

</LinearLayout>
