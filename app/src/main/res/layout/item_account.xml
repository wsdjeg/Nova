<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- 状态指示器 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="16dp">

        <!-- 激活状态圆点 -->
        <View
            android:id="@+id/account_status_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/session_icon_bg" />

        <!-- 最后使用时间 -->
        <TextView
            android:id="@+id/account_last_used"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:text="昨天" />

    </LinearLayout>

    <!-- 账号信息 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- 账号名称 -->
        <TextView
            android:id="@+id/account_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <!-- 服务器地址 -->
        <TextView
            android:id="@+id/account_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.1.100"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />

        <!-- 状态标签 -->
        <TextView
            android:id="@+id/account_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="当前激活"
            android:textSize="11sp"
            android:textColor="@color/primary"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- 操作按钮 -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- 激活按钮 -->
        <ImageButton
            android:id="@+id/account_activate_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="激活此账号"
            android:padding="8dp" />

        <!-- 编辑按钮 -->
        <ImageButton
            android:id="@+id/account_edit_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="编辑账号"
            android:padding="8dp" />

        <!-- 删除按钮 -->
        <ImageButton
            android:id="@+id/account_delete_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="删除账号"
            android:padding="8dp" />

    </LinearLayout>

</LinearLayout>
