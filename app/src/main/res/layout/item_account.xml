<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground">

    <!-- Status indicator -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:layout_marginEnd="16dp">

        <!-- Default status dot -->
        <View
            android:id="@+id/account_status_dot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/session_icon_bg" />

        <!-- Last used time -->
        <TextView
            android:id="@+id/account_last_used"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:text="@string/yesterday" />

    </LinearLayout>

    <!-- Account info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Account name -->
        <TextView
            android:id="@+id/account_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <!-- Server address -->
        <TextView
            android:id="@+id/account_url"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="192.168.1.100"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />

        <!-- Status label -->
        <TextView
            android:id="@+id/account_status_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/default_account"
            android:textSize="11sp"
            android:textColor="@color/primary"
            android:layout_marginTop="4dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Set default button -->
        <ImageButton
            android:id="@+id/account_default_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/set_default_account"
            android:padding="8dp" />

        <!-- Edit button -->
        <ImageButton
            android:id="@+id/account_edit_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/edit_account"
            android:padding="8dp" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/account_delete_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/delete_account"
            android:padding="8dp" />

    </LinearLayout>

</LinearLayout>

