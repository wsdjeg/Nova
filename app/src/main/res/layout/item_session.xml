<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="72dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?attr/selectableItemBackground">

    <!-- 
    布局说明：
    
    左侧内容区（标题、provider、cwd）
    右侧36dp区域（垂直居中，显示spinner或时间）
    
    第一行：账号标签 + 标题（垂直居中对齐）
    第二行：provider | model
    第三行：cwd
    
    右侧区域：spinner（进行中）或 时间（已完成），垂直居中
    
    分割线由 RecyclerView 的 DividerItemDecoration 提供
    -->

    <!-- 右侧区域容器：36dp宽，垂直居中于三行内容 -->
    <FrameLayout
        android:id="@+id/rightArea"
        android:layout_width="36dp"
        android:layout_height="36dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- 时间（默认显示） -->
        <TextView
            android:id="@+id/textSessionTime"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="12:00"
            android:textSize="12sp"
            android:textColor="#9E9E9E" />

        <!-- Spinner（进行中时显示，覆盖时间） -->
        <ProgressBar
            android:id="@+id/progressSpinner"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="21dp"
            android:layout_height="21dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="@color/primary" />
    </FrameLayout>

    <!-- 账号标签（垂直居中于标题） -->
    <TextView
        android:id="@+id/textAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="10sp"
        android:textColor="#1976D2"
        android:textStyle="bold"
        android:background="@drawable/account_tag_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/textSessionTitle"
        app:layout_constraintTop_toTopOf="@id/textSessionTitle" />

    <!-- 第一行：标题（账号标签存在时右移8dp，不存在时从左边开始） -->
    <TextView
        android:id="@+id/textSessionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Session Title"
        android:textSize="16sp"
        android:textColor="#212121"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toEndOf="@id/textAccount"
        app:layout_constraintEnd_toStartOf="@id/rightArea"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="8dp"
        app:layout_goneMarginStart="0dp" />

    <!-- 第二行：Provider | Model -->
    <TextView
        android:id="@+id/textProviderModel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="openai | gpt-4o"
        android:textSize="12sp"
        android:textColor="#616161"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightArea"
        app:layout_constraintTop_toBottomOf="@id/textSessionTitle" />

    <!-- 第三行：cwd -->
    <TextView
        android:id="@+id/textSessionCwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="/home/user/project"
        android:textSize="11sp"
        android:textColor="#9E9E9E"
        android:maxLines="1"
        android:ellipsize="start"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/rightArea"
        app:layout_constraintTop_toBottomOf="@id/textProviderModel" />

    <!-- 未读数量徽章（覆盖在右侧区域上角） -->
    <TextView
        android:id="@+id/textSessionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="99"
        android:textSize="10sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/session_count_bg"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:minWidth="16dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:translationY="-4dp"
        android:translationX="4dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
