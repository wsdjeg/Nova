<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="88dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- 第一行：账号标签 + 会话标题 + 时间 -->
    
    <!-- 账号标签 (显示来源账号) -->
    <TextView
        android:id="@+id/textAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="10sp"
        android:textColor="#1976D2"
        android:textStyle="bold"
        android:background="@drawable/account_tag_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 会话标题 (紧跟在账号标签后面) -->
    <TextView
        android:id="@+id/textSessionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Session Title"
        android:textSize="16sp"
        android:textColor="#212121"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintStart_toEndOf="@id/textAccount"
        app:layout_constraintEnd_toStartOf="@id/textSessionTime"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/textAccount" />

    <!-- Spinner (in_progress 状态图标，浮动在标题右边) -->
    <ProgressBar
        android:id="@+id/progressSpinner"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:layout_marginStart="4dp"
        android:visibility="gone"
        android:indeterminateTint="#1976D2"
        app:layout_constraintStart_toEndOf="@id/textSessionTitle"
        app:layout_constraintTop_toTopOf="@id/textSessionTitle"
        app:layout_constraintBottom_toBottomOf="@id/textSessionTitle" />

    <!-- 时间 -->
    <TextView
        android:id="@+id/textSessionTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:00"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/textAccount" />

    <!-- 第二行：消息预览 + 未读数量 -->
    
    <!-- 消息预览 (固定2行高度，与标题左端对齐) -->
    <TextView
        android:id="@+id/textSessionPreview"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="36dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="0dp"
        android:text="Message preview..."
        android:textSize="14sp"
        android:textColor="#757575"
        android:maxLines="2"
        android:ellipsize="end"
        android:gravity="top"
        app:layout_constraintStart_toStartOf="@id/textSessionTitle"
        app:layout_constraintEnd_toStartOf="@id/textSessionCount"
        app:layout_constraintTop_toBottomOf="@id/textSessionTitle" />

    <!-- 消息数量徽章 -->
    <TextView
        android:id="@+id/textSessionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="99"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/session_count_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:minWidth="20dp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSessionTime" />

    <!-- 分割线 -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="6dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
