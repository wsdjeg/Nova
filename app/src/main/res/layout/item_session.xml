<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="72dp"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- 
    布局说明：
    
    第一行：账号标签 + Spinner区域 + 标题 + 时间 + 未读数量
    第二行：provider | model
    第三行：cwd
    
    账号标签和 Spinner 位置保持不变
    -->

    <!-- 账号标签 (显示来源账号) -->
    <TextView
        android:id="@+id/textAccount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Home"
        android:textSize="10sp"
        android:textColor="#1976D2"
        android:textStyle="bold"
        android:background="@drawable/account_tag_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Barrier: 标题的起始位置 -->
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrierTitleStart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:barrierDirection="end"
        app:constraint_referenced_ids="textAccount" />

    <!-- Spinner 区域 (21dp × 21dp) -->
    <!-- 位于账号标签右侧，与账号标签顶部对齐 -->
    <ProgressBar
        android:id="@+id/progressSpinner"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="21dp"
        android:layout_height="21dp"
        android:visibility="gone"
        android:indeterminateTint="@color/primary"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/barrierTitleStart"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/textAccount" />

    <!-- 会话标题 -->
    <!-- 位于 Spinner 右侧（如果 Spinner 不可见则位于账号标签右侧） -->
    <TextView
        android:id="@+id/textSessionTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Session Title"
        android:textSize="16sp"
        android:textColor="#212121"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="8dp"
        app:layout_constraintStart_toEndOf="@id/progressSpinner"
        app:layout_constraintEnd_toStartOf="@id/textSessionTime"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/textAccount"
        app:layout_goneMarginStart="8dp" />

    <!-- 时间 -->
    <TextView
        android:id="@+id/textSessionTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="12:00"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:layout_marginEnd="8dp"
        app:layout_constraintEnd_toStartOf="@id/textSessionCount"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 消息数量徽章 -->
    <TextView
        android:id="@+id/textSessionCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="99"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/session_count_bg"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:minWidth="20dp"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 第二行：Provider | Model -->
    <TextView
        android:id="@+id/textProviderModel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="openai | gpt-4o"
        android:textSize="12sp"
        android:textColor="#616161"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textSessionTitle" />

    <!-- 第三行：cwd -->
    <TextView
        android:id="@+id/textSessionCwd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="/home/user/project"
        android:textSize="12sp"
        android:textColor="#9E9E9E"
        android:maxLines="1"
        android:ellipsize="start"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/textProviderModel" />

    <!-- 分割线 -->
    <View
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="8dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
