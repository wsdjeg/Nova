<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Toolbar with Session Info -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:popupTheme="@style/ThemeOverlay.AppCompat.Light"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="#CCCCCC"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationIconTint="@android:color/white">
        
        <!-- Session Info embedded in Toolbar - 3 lines -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginEnd="16dp">
            
            <!-- Line 1: Session Title (bold, white) -->
            <TextView
                android:id="@+id/tv_session_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新会话"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
            
            <!-- Line 2: Provider | Model -->
            <TextView
                android:id="@+id/tv_session_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="unknown | unknown"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="middle" />
            
            <!-- Line 3: Cwd path -->
            <TextView
                android:id="@+id/tv_session_path"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CWD: unknown"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="middle" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/inputLayout"
        android:layout_below="@id/toolbar"
        android:scrollbars="vertical"
        android:padding="8dp"
        android:clipToPadding="false"
        android:overScrollMode="always" />

    <!-- Load More Hint (overlay, shown when pulling down at top) -->
    <TextView
        android:id="@+id/tv_load_more"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_below="@id/toolbar"
        android:gravity="center"
        android:text="下拉加载更多"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:background="#4CAF50"
        android:visibility="gone"
        android:elevation="4dp" />

    <!-- Scroll to Bottom FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_scroll_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/inputLayout"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:src="@drawable/ic_arrow_down"
        android:visibility="gone"
        android:contentDescription="滚动到底部"
        app:backgroundTint="#FFFFFF"
        app:fabSize="mini" />

    <!-- Send Button - Fixed at screen bottom right -->
    <Button
        android:id="@+id/btn_send"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="12dp"
        android:layout_marginEnd="12dp"
        android:minHeight="0dp"
        android:text="发送"
        android:textColor="@android:color/white"
        android:textSize="16sp"
        android:includeFontPadding="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:background="@drawable/send_button_bg"
        app:backgroundTint="@null" />

    <!-- Input Area - Left of send button -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_toStartOf="@id/btn_send"
        android:orientation="vertical"
        android:padding="12dp"
        android:paddingEnd="8dp"
        android:background="#F5F5F5">

        <EditText
            android:id="@+id/et_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:maxHeight="100dp"
            android:background="@drawable/input_bg"
            android:hint="输入消息..."
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            android:scrollbars="vertical"
            android:importantForAutofill="no" />
    </LinearLayout>
</RelativeLayout>
