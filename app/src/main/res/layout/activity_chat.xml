<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Toolbar with Session Info -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="#CCCCCC">
        
        <!-- Session Info embedded in Toolbar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">
            
            <!-- Provider and Model info -->
            <TextView
                android:id="@+id/tv_session_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Provider: unknown | Model: unknown"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold" />
            
            <!-- Working directory path -->
            <TextView
                android:id="@+id/tv_session_path"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Path: unknown"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="middle" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/inputLayout"
        android:layout_below="@id/toolbar"
        android:scrollbars="vertical"
        android:padding="8dp" />

    <!-- Input Area -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#F5F5F5">

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入消息..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送"
            android:textSize="16sp"
            android:padding="12dp" />
    </LinearLayout>

</RelativeLayout>
