<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Toolbar with Session Info -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="?attr/colorPrimary"
        android:elevation="4dp"
        app:titleTextColor="@android:color/white"
        app:subtitleTextColor="#CCCCCC">
        
        <!-- Session Info embedded in Toolbar - 3 lines -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">
            
            <!-- Line 1: Session Title (bold, white) -->
            <TextView
                android:id="@+id/tv_session_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="新会话"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />
            
            <!-- Line 2: Provider | Model -->
            <TextView
                android:id="@+id/tv_session_info"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="unknown | unknown"
                android:textColor="#CCCCCC"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="middle" />
            
            <!-- Line 3: Cwd path -->
            <TextView
                android:id="@+id/tv_session_path"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CWD: unknown"
                android:textColor="#CCCCCC"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="middle" />
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <!-- Messages RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/inputLayout"
        android:layout_below="@id/toolbar"
        android:scrollbars="vertical"
        android:padding="8dp"
        android:clipToPadding="false"
        android:overScrollMode="always" />

    <!-- Load More Hint (overlay, shown when pulling down at top) -->
    <TextView
        android:id="@+id/tv_load_more"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_below="@id/toolbar"
        android:gravity="center"
        android:text="下拉加载更多"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:background="#4CAF50"
        android:visibility="gone"
        android:elevation="4dp" />

    <!-- Scroll to Bottom FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_scroll_bottom"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/inputLayout"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_arrow_down"
        android:visibility="gone"
        android:contentDescription="滚动到底部"
        app:backgroundTint="#FFFFFF"
        app:fabSize="mini" />

    <!-- Input Area -->
    <LinearLayout
        android:id="@+id/inputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#F5F5F5">

        <EditText
            android:id="@+id/et_message"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="输入消息..."
            android:inputType="textMultiLine"
            android:maxLines="4"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:layout_marginEnd="8dp"
            android:importantForAutofill="no" />

        <Button
            android:id="@+id/btn_send"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="发送"
            android:textSize="16sp"
            android:padding="12dp" />
    </LinearLayout>

</RelativeLayout>
