<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - 使用 NoActionBar 因为使用 Toolbar -->
    <style name="Base.Theme.MyAndroidApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/primary_color</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
    </style>

    <style name="Theme.MyAndroidApp" parent="Base.Theme.MyAndroidApp" />

    <!-- Popup menu overlay - adapts to light/dark mode -->
    <style name="ToolbarPopupOverlay" parent="ThemeOverlay.AppCompat">
        <item name="android:colorBackground">@color/popup_bg</item>
        <item name="android:textColorPrimary">@color/popup_text</item>
    </style>
</resources>
