<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Nova Launcher Background - Deep Dark Gradient -->
    <!-- 使用 layer-list + shape 实现渐变背景 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0D1117"
                android:endColor="#1F2937"/>
        </shape>
    </item>
</layer-list>
