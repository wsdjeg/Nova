<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <!-- Nova "N" Logo - About Page High Resolution Version -->
    <!-- 尺寸: 200dp (高清版本) -->
    <!-- 完全匹配 app logo 设计 -->
    
    <!-- 背景 - 深色渐变 -->
    <path
        android:pathData="M0,0h200v200H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="200"
                android:endY="200"
                android:startColor="#0D1117"
                android:endColor="#1F2937"/>
        </aapt:attr>
    </path>
    
    <!-- N 字母 - 完全匹配 ic_launcher_foreground.xml 的比例 -->
    <!-- 原始设计 (54dp viewport, 偏移 8,8): -->
    <!--   左竖线: x=0~5.5, y=0~38, 宽=5.5 -->
    <!--   右竖线: x=32.5~38, y=0~38, 宽=5.5 -->
    <!--   斜线角度: atan(38/32.5) ≈ 49.5° -->
    <!--   斜线四边形: (0,0)->(5.5,0)->(38,38)->(32.5,38) -->
    
    <!-- 放大到 100dp viewport (放大比例: 100/38 ≈ 2.63) -->
    <!-- 线宽: 5.5 × 2.63 ≈ 14.5 -->
    <!-- 两竖线间距: 32.5 × 2.63 ≈ 85.5 -->
    <!-- 高度: 38 × 2.63 ≈ 100 -->
    
    <group
        android:translateX="50"
        android:translateY="50">
        
        <group
            android:translateX="0"
            android:translateY="0">
            
            <!-- 左竖线: x=0~14.5, y=0~100 -->
            <path
                android:pathData="M0,0 L14.5,0 L14.5,100 L0,100 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="0"
                        android:startY="0"
                        android:endX="0"
                        android:endY="100"
                        android:startColor="#00C2FF"
                        android:endColor="#4DB8E8"/>
                </aapt:attr>
            </path>
            
            <!-- 右竖线: x=85.5~100, y=0~100 -->
            <path
                android:pathData="M85.5,0 L100,0 L100,100 L85.5,100 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="85.5"
                        android:startY="0"
                        android:endX="85.5"
                        android:endY="100"
                        android:startColor="#9B6EF6"
                        android:endColor="#6C5CE7"/>
                </aapt:attr>
            </path>
            
            <!-- 斜线: 四边形 (0,0)->(14.5,0)->(100,100)->(85.5,100) -->
            <!-- 角度 = atan(100/85.5) = atan(1.169) ≈ 49.5° -->
            <path
                android:pathData="M0,0 L14.5,0 L100,100 L85.5,100 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="0"
                        android:startY="0"
                        android:endX="100"
                        android:endY="100"
                        android:startColor="#00C2FF"
                        android:endColor="#6C5CE7"/>
                </aapt:attr>
            </path>
            
        </group>
        
    </group>
    
</vector>
