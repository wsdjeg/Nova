<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <!-- Nova "N" Logo - About Page High Resolution Version -->
    <!-- 完全匹配 https://github.com/wsdjeg/Nova/ic_launcher.xml -->
    
    <!-- 背景 - 深色渐变 (匹配原始设计) -->
    <path
        android:pathData="M0,0h200v200H0z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="200"
                android:endY="200"
                android:startColor="#0D1117"
                android:endColor="#1F2937"/>
        </aapt:attr>
    </path>
    
    <!-- N 字母主体 - 完全匹配原始比例 -->
    <!-- 原始设计 (48dp viewport): -->
    <!--   左竖线: x=-10.5~-6, y=-12~12 (宽 4.5, 高 24) -->
    <!--   右竖线: x=6~10.5, y=-12~12 (宽 4.5, 高 24) -->
    <!--   斜线: M-6,-12 L-2,-12 L6,12 L2,12 Z -->
    <!--   斜线顶边: x=-6~-2 (宽 4) -->
    <!--   斜线底边: x=2~6 (宽 4) -->
    
    <!-- 放大到 200dp: 比例 = 200/48 ≈ 4.167 -->
    <!-- 竖线宽度: 4.5 × 4.167 ≈ 18.75 -->
    <!-- 竖线高度: 24 × 4.167 = 100 -->
    <!-- 左竖线: x=-43.75~-25, y=-50~50 -->
    <!-- 右竖线: x=25~43.75, y=-50~50 -->
    <!-- 斜线: M-25,-50 L-8.33,-50 L25,50 L8.33,50 Z -->
    
    <group
        android:translateX="100"
        android:translateY="100">
        
        <!-- 左竖线: x=-43.75~-25, y=-50~50 -->
        <path
            android:pathData="M-43.75,-50 L-25,-50 L-25,50 L-43.75,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="-43.75"
                    android:startY="-50"
                    android:endX="-43.75"
                    android:endY="50"
                    android:startColor="#00C2FF"
                    android:endColor="#4DB8E8"/>
            </aapt:attr>
        </path>
        
        <!-- 右竖线: x=25~43.75, y=-50~50 -->
        <path
            android:pathData="M25,-50 L43.75,-50 L43.75,50 L25,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="25"
                    android:startY="-50"
                    android:endX="25"
                    android:endY="50"
                    android:startColor="#9B6EF6"
                    android:endColor="#6C5CE7"/>
            </aapt:attr>
        </path>
        
        <!-- 斜线: M-25,-50 L-8.33,-50 L25,50 L8.33,50 Z -->
        <!-- 斜线顶边与左竖线相邻 (左竖线右边 x=-25, 斜线顶边左边 x=-25) -->
        <!-- 斜线底边与右竖线相邻 (斜线底边右边 x=8.33, 右竖线左边 x=25) -->
        <!-- 但原始设计中斜线底边是 x=2~6, 右竖线是 x=6~10.5 -->
        <!-- 所以斜线底边右边 x=6 与右竖线左边 x=6 相邻 -->
        <!-- 放大后: 斜线底边 x=8.33~25, 右竖线 x=25~43.75 -->
        <path
            android:pathData="M-25,-50 L-8.33,-50 L25,50 L8.33,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="-25"
                    android:startY="-50"
                    android:endX="25"
                    android:endY="50"
                    android:startColor="#00C2FF"
                    android:endColor="#6C5CE7"/>
            </aapt:attr>
        </path>
        
    </group>
    
</vector>
