<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    
    <!-- Nova "N" Logo - About Page High Resolution Version -->
    <!-- 完全匹配 https://github.com/wsdjeg/Nova/ic_launcher.xml -->
    <!-- 背景添加圆角 -->
    
    <!-- 背景 - 深色渐变 (圆角矩形) -->
    <!-- 圆角半径: 16dp -->
    <path
        android:pathData="M16,0
                          L184,0
                          Q200,0 200,16
                          L200,184
                          Q200,200 184,200
                          L16,200
                          Q0,200 0,184
                          L0,16
                          Q0,0 16,0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="200"
                android:endY="200"
                android:startColor="#0D1117"
                android:endColor="#1F2937"/>
        </aapt:attr>
    </path>
    
    <!-- N 字母主体 - 完全匹配原始比例 -->
    <group
        android:translateX="100"
        android:translateY="100">
        
        <!-- 左竖线: x=-43.75~-25, y=-50~50 -->
        <path
            android:pathData="M-43.75,-50 L-25,-50 L-25,50 L-43.75,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="-43.75"
                    android:startY="-50"
                    android:endX="-43.75"
                    android:endY="50"
                    android:startColor="#00C2FF"
                    android:endColor="#4DB8E8"/>
            </aapt:attr>
        </path>
        
        <!-- 右竖线: x=25~43.75, y=-50~50 -->
        <path
            android:pathData="M25,-50 L43.75,-50 L43.75,50 L25,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="25"
                    android:startY="-50"
                    android:endX="25"
                    android:endY="50"
                    android:startColor="#9B6EF6"
                    android:endColor="#6C5CE7"/>
            </aapt:attr>
        </path>
        
        <!-- 斜线: M-25,-50 L-8.33,-50 L25,50 L8.33,50 Z -->
        <path
            android:pathData="M-25,-50 L-8.33,-50 L25,50 L8.33,50 Z">
            <aapt:attr name="android:fillColor">
                <gradient
                    android:type="linear"
                    android:startX="-25"
                    android:startY="-50"
                    android:endX="25"
                    android:endY="50"
                    android:startColor="#00C2FF"
                    android:endColor="#6C5CE7"/>
            </aapt:attr>
        </path>
        
    </group>
    
</vector>
