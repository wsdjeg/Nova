<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Nova "N" Logo - 前景层 (108dp) -->
    <!-- 安全区域 72dp，边距 18dp -->
    
    <group
        android:translateX="54"
        android:translateY="54">
        
        <!-- N 字母主体 - 几何科技风格 -->
        
        <!-- 左竖线 -->
        <path
            android:fillColor="#00D4FF"
            android:pathData="M-26,-28 L-18,-28 L-18,28 L-26,28 Z"/>
        
        <!-- 右竖线 -->
        <path
            android:fillColor="#7C4DFF"
            android:pathData="M18,-28 L26,-28 L26,28 L18,28 Z"/>
        
        <!-- 斜线 - 渐变效果用两个三角形 -->
        <path
            android:fillColor="#00BCD4"
            android:pathData="M-18,-28 L-10,-28 L18,28 L10,28 Z"/>
        
        <!-- 斜线高光 -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.3"
            android:pathData="M-18,-28 L-14,-28 L14,28 L10,28 Z"/>
        
        <!-- 左竖线内发光 -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.4"
            android:pathData="M-26,-28 L-22,-28 L-22,28 L-26,28 Z"/>
        
        <!-- 右竖线内发光 -->
        <path
            android:fillColor="#FFFFFF"
            android:fillAlpha="0.2"
            android:pathData="M22,-28 L26,-28 L26,28 L22,28 Z"/>
        
        <!-- 外发光效果 -->
        <path
            android:strokeColor="#00D4FF"
            android:strokeWidth="1"
            android:strokeAlpha="0.5"
            android:fillColor="@android:color/transparent"
            android:pathData="M-26,-28 L-26,28 L-18,28 L10,-28 L18,-28 L18,28 L26,28 L26,-28 Z"/>
        
        <!-- 顶部光晕 -->
        <path
            android:fillColor="#00FFFF"
            android:fillAlpha="0.15"
            android:pathData="M-26,-30 L26,-30 L26,-28 L-26,-28 Z"/>
        
        <!-- 底部光晕 -->
        <path
            android:fillColor="#7C4DFF"
            android:fillAlpha="0.2"
            android:pathData="M-26,28 L26,28 L26,30 L-26,30 Z"/>
        
    </group>
</vector>
