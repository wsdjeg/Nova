<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Nova "N" Foreground - Adaptive Icon -->
    <!-- 尺寸: 108dp (adaptive icon 标准) -->
    <!-- 安全区域: 72dp (中心区域) -->
    <!-- N 字母居中，cyan → purple 渐变 -->
    
    <group
        android:translateX="27"
        android:translateY="27">
        
        <!-- 放大的 N 字母 (54dp viewport, 占 70%) -->
        <group
            android:translateX="8"
            android:translateY="8">
            
            <!-- 左竖线 -->
            <path
                android:pathData="M0,0 L5.5,0 L5.5,38 L0,38 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="0"
                        android:startY="0"
                        android:endX="0"
                        android:endY="38"
                        android:startColor="#00C2FF"
                        android:endColor="#4DB8E8"/>
                </aapt:attr>
            </path>
            
            <!-- 右竖线 -->
            <path
                android:pathData="M32.5,0 L38,0 L38,38 L32.5,38 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="32.5"
                        android:startY="0"
                        android:endX="32.5"
                        android:endY="38"
                        android:startColor="#9B6EF6"
                        android:endColor="#6C5CE7"/>
                </aapt:attr>
            </path>
            
            <!-- 斜线 -->
            <path
                android:pathData="M0,0 L5.5,0 L38,38 L32.5,38 Z">
                <aapt:attr name="android:fillColor">
                    <gradient
                        android:type="linear"
                        android:startX="0"
                        android:startY="0"
                        android:endX="38"
                        android:endY="38"
                        android:startColor="#00C2FF"
                        android:endColor="#6C5CE7"/>
                </aapt:attr>
            </path>
            
        </group>
        
    </group>
    
</vector>
