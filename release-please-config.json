{
  "packages": {
    ".": {
      "release-type": "simple",
      "package-name": "Nova",
      "changelog-path": "CHANGELOG.md",
      "bump-minor-pre-major": true,
      "bump-patch-for-minor-pre-major": false,
      "draft": false,
      "prerelease": false,
      "extra-files": [
        {
          "type": "generic",
          "path": "app/build.gradle",
          "line": [
            {
              "match": "versionCode \\d+",
              "replace": "versionCode {{version}}"
            },
            {
              "match": "versionName [\"'].*[\"']",
              "replace": "versionName \"{{version}}\""
            }
          ]
        }
      ]
    }
  }
}
